# Copy this file to .env and adjust values for your local setup.
# .env is git-ignored — never commit real credentials.

# Source database (sourcedb, port 5433)
SOURCE_HOST=localhost
SOURCE_PORT=5433
SOURCE_DB=sourcedb

# Destination database (destdb, port 5434)
DEST_HOST=localhost
DEST_PORT=5434
DEST_DB=destdb

# Shared credentials (used for both databases)
DB_USER=demo
DB_PASSWORD=demo

# Sync settings
STATE_FILE=last_sync.txt
BATCH_SIZE=500
